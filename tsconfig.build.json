{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["src/**/*", "typings/**/*.d.ts"],
  "exclude": ["**/*.test.*", "**/*.spec.*", "test/**/*"]
}
